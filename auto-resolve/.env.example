# Local-only example. The deployer copies this to .env or sources from ~/.reverb/.
# RESOLVER_PRIVATE_KEY must come from ~/.reverb/operator-resolver.key with sibling .md.
RPC_URL=http://127.0.0.1:8545
OPERATOR_ADDRESS=0x0000000000000000000000000000000000000000
RESOLVER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# FRED_API_KEY=  # leave unset; BLS-only registries do not need it
REGISTRY_PATH=registry/markets.json
RUST_LOG=auto_resolve=info,warn
